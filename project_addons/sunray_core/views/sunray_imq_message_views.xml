<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════════════════════════════
         IMQ MESSAGE - Sunray Action Window
         Reuses existing IMQ views (tree, form, search)
         ═══════════════════════════════════════════════════════════════════════ -->

    <record id="sunray_imq_message__actwindow" model="ir.actions.act_window">
        <field name="name">My Tasks</field>
        <field name="res_model">imq.message</field>
        <field name="view_mode">list,form</field>
        <field name="help">Browse asynchronous tasks (deployments, backups, etc.)</field>
        <field name="context">{
            'search_default_filter_pending': True,
            'search_default_filter_wip': True,
            'search_default_filter_failed': True,
            'search_default_filter_retry': True,
            'search_default_filter_today': True,
        }</field>
    </record>

</odoo>
