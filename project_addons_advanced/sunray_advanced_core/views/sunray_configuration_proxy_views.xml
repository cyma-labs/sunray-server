<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sunray Configuration Proxy (SCP) Management Views -->

    <!-- List View -->
    <record id="sunray_configuration_proxy__listview" model="ir.ui.view">
        <field name="name">sunray.configuration_proxy.list</field>
        <field name="model">sunray.configuration_proxy</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="url"/>
                <field name="fqdn_regex" optional="show"/>
                <field name="host_count"/>
                <field name="user_count" optional="show"/>
                <field name="last_sync_ts" optional="show"/>
                <field name="is_active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="sunray_configuration_proxy__formview" model="ir.ui.view">
        <field name="name">sunray.configuration_proxy.form</field>
        <field name="model">sunray.configuration_proxy</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="is_active" widget="boolean_toggle"/>
                    </group>

                    <group>
                        <field name="url" widget="url"/>
                        <field name="token" widget="inouk_password_char"/>
                    </group>

                    <group>
                        <field name="fqdn_regex" help="Regex pattern for FQDNs this SCP manages. Empty = match all."/>
                    </group>

                    <!-- Status Information -->
                    <group string="Sync Status" class="oe_read_only">
                        <field name="last_sync_ts" readonly="1"/>
                        <field name="last_error" readonly="1" widget="text"/>
                    </group>

                    <!-- Counts -->
                    <group string="Managed Resources" class="oe_read_only">
                        <field name="host_count" readonly="1"/>
                        <field name="user_count" readonly="1"/>
                    </group>

                    <!-- Managed Hosts Tab -->
                    <notebook>
                        <page string="Managed Hosts" name="hosts_tab">
                            <field name="host_ids" readonly="1" nolabel="1">
                                <list>
                                    <field name="domain"/>
                                    <field name="is_active" widget="boolean_toggle"/>
                                    <field name="scp_sync_enabled" widget="boolean_toggle"/>
                                    <field name="scp_last_sync_ts" optional="show"/>
                                </list>
                            </field>
                        </page>

                        <page string="Managed Users" name="users_tab">
                            <field name="user_ids" readonly="1" nolabel="1" widget="many2many_tags"/>
                        </page>

                        <page string="Access Rules" name="rules_tab">
                            <field name="access_rule_ids" readonly="1" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="access_type"/>
                                    <field name="is_active" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>

                        <page string="Linked Workers" name="workers_tab">
                            <field name="worker_ids" readonly="1" nolabel="1" widget="many2many_tags"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="sunray_configuration_proxy__searchview" model="ir.ui.view">
        <field name="name">sunray.configuration_proxy.search</field>
        <field name="model">sunray.configuration_proxy</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Name"/>
                <field name="url" string="URL"/>
                <field name="fqdn_regex" string="FQDN Pattern"/>
                <filter name="active" string="Active" domain="[('is_active', '=', True)]"/>
                <filter name="inactive" string="Inactive" domain="[('is_active', '=', False)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_by_status" string="Status"
                        context="{'group_by': 'is_active'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action Window -->
    <record id="sunray_configuration_proxy__actwindow" model="ir.actions.act_window">
        <field name="name">Configuration Proxies</field>
        <field name="res_model">sunray.configuration_proxy</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Sunray Configuration Proxy (SCP) to enable auto-registration.
            </p>
            <p>
                SCPs are external HTTP APIs that return configuration for protected hosts.
                Link an SCP to a worker to enable automatic host setup when users first visit.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="sunray_configuration_proxy__menu"
        name="Configuration Proxies"
        action="sunray_configuration_proxy__actwindow"
        parent="sunray_core.menu_sunray_infrastructure"
        sequence="40"/>

</odoo>
